{
  "name": "conserto-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "app1:start": "ng serve --project conserto-app",
    "app1:build": "ng build --project conserto-app",
    "app1:watch": "ng build --watch --configuration development --project conserto-app",
    "app1:test": "ng test --project conserto-app",
    "app1:doc:serve": "npx compodoc -s -o -p projects/conserto-app/tsconfig.doc.json -d ./documentation/app-1",
    "app2:start": "ng serve --project cts-app-2",
    "app2:build": "ng build --project cts-app-2",
    "app2:watch": "ng build --watch --configuration development --project cts-app-2",
    "app2:test": "ng test --project cts-app-2",
    "app2:doc:serve": "npx compodoc -s -o -p projects/cts-app-2/tsconfig.doc.json -d ./documentation/app-2",
    "lib:ui": "ng build --project lib-cts-ui",
    "lib:ui:doc:serve": "npx compodoc -s -o -p projects/lib-cts-ui/tsconfig.doc.json -d ./documentation/lib-cts-ui",
    "prelib:ui:pack": "npm run lib:ui",
    "lib:ui:pack": "npm pack ./dist/lib-cts-ui --pack-destination ./packages",
    "lib:core": "ng build --project lib-cts-core",
    "lib:core:doc:serve": "npx compodoc -s -o -p projects/lib-cts-core/tsconfig.doc.json -d ./documentation/lib-cts-core"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@compodoc/compodoc": "^1.2.1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
